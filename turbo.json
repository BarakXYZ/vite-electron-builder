{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["pnpm-lock.yaml"],
  "tasks": {
    "//#lint:fix:root": {
      "cache": false,
      "inputs": [
        "package.json",
        "pnpm-workspace.yaml",
        "turbo.json",
        "oxlint.config.ts",
        "oxlint.desktop.config.ts",
        "oxlint.tests.config.ts",
        "oxlint.ui.config.ts",
        "README.md",
        "CONTRIBUTING.md",
        ".github/**"
      ],
      "outputs": []
    },
    "//#lint:root": {
      "inputs": [
        "package.json",
        "pnpm-workspace.yaml",
        "turbo.json",
        "oxlint.config.ts",
        "oxlint.desktop.config.ts",
        "oxlint.tests.config.ts",
        "oxlint.ui.config.ts",
        "README.md",
        "CONTRIBUTING.md",
        ".github/**"
      ],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "env": ["VITE_DISTRIBUTION_CHANNEL"],
      "outputs": ["dist/**"]
    },
    "compile": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["VITE_DISTRIBUTION_CHANNEL"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "lint:type-aware": {
      "outputs": []
    },
    "lint:typecheck": {
      "outputs": []
    },
    "test": {
      "cache": false,
      "env": ["APP_E2E_WINDOW_MODE", "CI"],
      "outputs": []
    },
    "test:background": {
      "cache": false,
      "env": ["APP_E2E_WINDOW_MODE", "CI"],
      "outputs": []
    },
    "test:hidden": {
      "cache": false,
      "env": ["APP_E2E_WINDOW_MODE", "CI"],
      "outputs": []
    },
    "test:interactive": {
      "cache": false,
      "env": ["APP_E2E_WINDOW_MODE", "CI"],
      "outputs": []
    },
    "transit": {
      "dependsOn": ["^transit"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    }
  }
}
