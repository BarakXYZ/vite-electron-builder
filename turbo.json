{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["pnpm-lock.yaml", "pnpm-workspace.yaml"],
  "tasks": {
    "//#lint:fix:root": {
      "cache": false,
      "inputs": [
        "package.json",
        "pnpm-workspace.yaml",
        "turbo.json",
        "oxlint.config.ts",
        "oxlint.desktop.config.ts",
        "oxlint.tests.config.ts",
        "oxlint.ui.config.ts",
        "README.md",
        "CONTRIBUTING.md",
        ".github/**"
      ],
      "outputs": []
    },
    "//#lint:root": {
      "inputs": [
        "package.json",
        "pnpm-workspace.yaml",
        "turbo.json",
        "oxlint.config.ts",
        "oxlint.desktop.config.ts",
        "oxlint.tests.config.ts",
        "oxlint.ui.config.ts",
        "README.md",
        "CONTRIBUTING.md",
        ".github/**"
      ],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/oxlint.config.ts",
        "$TURBO_ROOT$/oxlint.desktop.config.ts",
        "$TURBO_ROOT$/oxlint.tests.config.ts",
        "$TURBO_ROOT$/oxlint.ui.config.ts"
      ],
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/oxlint.config.ts",
        "$TURBO_ROOT$/oxlint.desktop.config.ts",
        "$TURBO_ROOT$/oxlint.tests.config.ts",
        "$TURBO_ROOT$/oxlint.ui.config.ts"
      ]
    },
    "lint:type-aware": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/oxlint.config.ts",
        "$TURBO_ROOT$/oxlint.desktop.config.ts",
        "$TURBO_ROOT$/oxlint.tests.config.ts",
        "$TURBO_ROOT$/oxlint.ui.config.ts"
      ],
      "outputs": []
    },
    "lint:typecheck": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/oxlint.config.ts",
        "$TURBO_ROOT$/oxlint.desktop.config.ts",
        "$TURBO_ROOT$/oxlint.tests.config.ts",
        "$TURBO_ROOT$/oxlint.ui.config.ts"
      ],
      "outputs": []
    },
    "transit": {
      "dependsOn": ["^transit"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    }
  }
}
