{
  "name": "electron-xyz-workspace",
  "version": "3.1.0",
  "private": true,
  "description": "Monorepo-ready Electron workspace powered by Turborepo and pnpm",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "compile": "turbo run compile --filter=@app/desktop",
    "dev": "turbo run dev --filter=@app/desktop",
    "dev:app": "pnpm --filter @app/desktop dev:app",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "turbo run lint lint:root",
    "lint:fix": "turbo run lint:fix lint:fix:root --continue=always",
    "lint:fix:root": "oxlint oxlint.config.ts oxlint.desktop.config.ts oxlint.tests.config.ts oxlint.ui.config.ts --fix && oxfmt package.json turbo.json pnpm-workspace.yaml README.md .github",
    "lint:root": "oxlint oxlint.config.ts oxlint.desktop.config.ts oxlint.tests.config.ts oxlint.ui.config.ts && oxfmt --check package.json turbo.json pnpm-workspace.yaml README.md .github",
    "lint:type-aware": "turbo run lint:type-aware",
    "lint:typecheck": "turbo run lint:typecheck",
    "shadcn:add": "pnpm run shadcn:add:app",
    "shadcn:add:app": "pnpm dlx shadcn@latest add --cwd packages/desktop-renderer",
    "shadcn:add:ui": "pnpm dlx shadcn@latest add --cwd packages/ui",
    "start": "pnpm run dev:app",
    "test": "turbo run test --filter=@app/desktop",
    "test:background": "turbo run test:background --filter=@app/desktop",
    "test:hidden": "turbo run test:hidden --filter=@app/desktop",
    "test:interactive": "turbo run test:interactive --filter=@app/desktop",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/oxlint-config": "^1.0.1",
    "@playwright/test": "1.58.2",
    "@types/node": "25.3.3",
    "@typescript/native-preview": "7.0.0-dev.20260304.1",
    "electron": "40.7.0",
    "electron-builder": "26.8.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "glob": "13.0.6",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "turbo": "^2.6.0",
    "vite": "7.3.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.19.0"
}
