{
  "name": "electron-xyz-workspace",
  "version": "3.1.0",
  "private": true,
  "description": "Monorepo-ready Electron workspace powered by Turborepo and pnpm",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "compile": "pnpm --filter @app/desktop compile",
    "dev": "pnpm --filter @app/desktop start",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix --continue=always",
    "lint:type-aware": "turbo run lint:type-aware",
    "lint:typecheck": "turbo run lint:typecheck",
    "shadcn:add": "pnpm run shadcn:add:app",
    "shadcn:add:app": "pnpm dlx shadcn@latest add --cwd packages/desktop-renderer",
    "shadcn:add:ui": "pnpm dlx shadcn@latest add --cwd packages/ui",
    "start": "pnpm run dev",
    "test": "pnpm --filter @app/desktop test",
    "test:background": "pnpm --filter @app/desktop test:background",
    "test:hidden": "pnpm --filter @app/desktop test:hidden",
    "test:interactive": "pnpm --filter @app/desktop test:interactive",
    "typecheck": "turbo run typecheck",
    "create-renderer": "pnpm --filter @app/desktop-integrate-renderer create-renderer",
    "integrate-renderer": "pnpm --filter @app/desktop-integrate-renderer start",
    "init": "node -e \"const fs=require('node:fs');process.exit(fs.existsSync('packages/desktop-renderer')?0:1)\" || (pnpm run create-renderer && pnpm run integrate-renderer) && pnpm install"
  },
  "devDependencies": {
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/oxlint-config": "^1.0.1",
    "@playwright/test": "1.58.2",
    "@types/node": "25.3.3",
    "@typescript/native-preview": "7.0.0-dev.20260304.1",
    "create-vite": "8.3.0",
    "electron": "40.7.0",
    "electron-builder": "26.8.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "glob": "13.0.6",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "^1.58.2",
    "turbo": "^2.6.0",
    "vite": "7.3.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.19.0"
}
