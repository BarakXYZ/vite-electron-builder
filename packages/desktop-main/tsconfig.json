{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "module": "NodeNext",
    "target": "ESNext",
    "sourceMap": false,
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "@app/desktop-preload": ["../desktop-preload"],
      "@app/desktop-renderer": ["../desktop-renderer"]
    }
  },
  "include": ["src/**/*.ts", "../../apps/desktop/types/**/*.d.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"]
}
