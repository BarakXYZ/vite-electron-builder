{
  "name": "@app/desktop-renderer",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist/**"
  ],
  "type": "module",
  "main": "./dist/index.html",
  "exports": {
    ".": {
      "default": "./dist/index.html"
    }
  },
  "scripts": {
    "build": "tsgo -b && vite build --base ./ --configLoader runner",
    "dev": "vite --configLoader runner",
    "lint": "oxlint . --config ../../oxlint.config.ts",
    "lint:fix": "oxlint . --config ../../oxlint.config.ts --fix",
    "lint:type-aware": "oxlint . --config ../../oxlint.config.ts --type-aware",
    "lint:typecheck": "oxlint . --config ../../oxlint.config.ts --type-aware --type-check",
    "preview": "vite preview",
    "typecheck": "tsgo -b"
  },
  "devDependencies": {
    "@app/desktop-preload": "workspace:*",
    "@app/ui": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
