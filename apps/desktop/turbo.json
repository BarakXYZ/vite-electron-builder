{
  "extends": ["//"],
  "tasks": {
    "build": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["VITE_DISTRIBUTION_CHANNEL"],
      "outputs": ["dist/**"]
    },
    "compile": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["VITE_DISTRIBUTION_CHANNEL"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "interruptible": true,
      "outputs": [],
      "persistent": true,
      "with": ["@app/desktop-renderer#dev", "@app/desktop-main#dev", "@app/desktop-preload#dev"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["APP_E2E_WINDOW_MODE", "CI"],
      "outputs": [],
      "passThroughEnv": ["PLAYWRIGHT_*"]
    },
    "test:background": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["APP_E2E_WINDOW_MODE", "CI"],
      "outputs": [],
      "passThroughEnv": ["PLAYWRIGHT_*"]
    },
    "test:hidden": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["APP_E2E_WINDOW_MODE", "CI"],
      "outputs": [],
      "passThroughEnv": ["PLAYWRIGHT_*"]
    },
    "test:interactive": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["APP_E2E_WINDOW_MODE", "CI"],
      "outputs": [],
      "passThroughEnv": ["PLAYWRIGHT_*"]
    }
  }
}
